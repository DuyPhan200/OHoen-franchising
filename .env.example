# Vite Environment Variables Template
# Copy this file to .env and fill in your values
# Note: Variables must be prefixed with VITE_ to be exposed to the client

# Application Configuration
VITE_APP_NAME=Bún Mee
VITE_APP_VERSION=1.0.0

# API Configuration (if needed in the future)
# VITE_API_BASE_URL=http://localhost:3000/api
# VITE_API_TIMEOUT=10000

# Image Assets
VITE_HERO_IMAGE_PATH=/herosection.png

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false

# External Services (add as needed)
# VITE_GOOGLE_MAPS_API_KEY=your_api_key_here
# VITE_ANALYTICS_ID=your_analytics_id_here
